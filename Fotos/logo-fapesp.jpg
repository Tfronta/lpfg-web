    <script src="https://fapesp.br/assets/js/acorddion.proposta.min.js"></script>
    <script src="https://fapesp.br/assets/vendor/admin/select2/js/select2.min.js"></script>
    <script src="https://fapesp.br/assets/vendor/admin/select2/js/i18n/pt-BR.js"></script>





    <script>

        /* $('h1,h2,h3,h4,p,span,b, .text,.section , .b,.info,.description,.datePublic, body main>#biblioteca-virtual ul>li>a, body>footer ul>li a,.DescMembro,.accordion-header').FontSize({
            increaseTimes: 5,
            reduceTimes: 5,
        }); */

        if($('#pais.select2').length){
            $(".select2").select2({
                "language": "pt-BR"
            });
            div_country = '';

            let isMobile = window.matchMedia("only screen and (max-width: 760px)").matches;

            if (!isMobile) {
                $('.select2.select2-container').css('width', '570px').css('display', 'block');
            }
            $('#pais').change(function(){

                //$('.d-none').hide();
                let pais = $('#pais').val();
                $(div_country).addClass('d-none');

                switch (pais) {
                    case 'Estados Unidos':
                    case 'Demais localidades':
                        $('.estados-unidos').removeClass('d-none');
                        div_country = '.estados-unidos';
                        break;
                    case 'Canadá':
                        $('.canada').removeClass('d-none');
                        div_country = '.canada';
                        break;
                    case 'Austrália':
                        $('.australia').removeClass('d-none');
                        div_country = '.australia';
                        break;
                    case 'Nova Zelândia':
                        $('.nova-zelandia').removeClass('d-none');
                        div_country = '.nova-zelandia';
                        break;
                    case 'México':
                        $('.mexico').removeClass('d-none');
                        div_country = '.mexico';
                        break;
                    case 'Japão':
                        $('.japao').removeClass('d-none');
                        div_country = '.japao';
                        break;
                    case 'Suíça':
                    case 'Europa (exceto Reino Unido)':
                    case 'Reino Unido (Inglaterra, Escócia, País de Gales e Irlanda do Norte)':
                        $('.suica').removeClass('d-none');
                        div_country = '.suica';
                        break;
                }

            });

            $('.uppercase').change(function (){
                $(this).val($(this).val().toUpperCase());
                console.log($(this).val());
            })

        }
    </script>

    

    <!-- create initialization -->
    <script>
        const nanoExpansion = new NanoExpansion({
            wrapper: "#myexpansion",
            duration: 0.2,
            autoFolding: true,
        });
    </script>


    <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>
    <script>
    new window.VLibras.Widget('https://vlibras.gov.br/app');
    </script>

    <script>
        $(function() {
            $("#phoneField").inputmask("(99) 99999-999[9]", {
                clearIncomplete: true
            });

            $("#processField").inputmask("9999/99999-9", {
                clearIncomplete: true
            });

            $("#agencyField").inputmask("9999", {
                clearIncomplete: true
            });

            $("#DigitagencyField").inputmask("*", {
                clearIncomplete: true
            });

            $("#accountField").inputmask("99{1,6}", {
                clearIncomplete: true
            });

            $('#healthInsuranceField').maskMoney();
            $('#transportField').maskMoney();

            $(".money").maskMoney();
        });


    function sizeOfThings(){
    var windowWidth = window.innerWidth;
    var windowHeight = window.innerHeight;
    var screenWidth = screen.width;
    var screenHeight = screen.height;
   alert("Tela.:"+ screenWidth+" X "+screenHeight);
};



</script>


